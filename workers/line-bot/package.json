{
  "name": "github-claw-dev-line-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "bun build ./src/index.js --outfile ./dist/index.mjs --target browser --format esm",
    "dev": "test -n \"$WORKER_NAME\" && bunx wrangler dev --name \"$WORKER_NAME\"",
    "deploy": "bun run build && test -n \"$WORKER_NAME\" && bunx wrangler deploy --name \"$WORKER_NAME\"",
    "set": "test -n \"$WORKER_NAME\" && bunx wrangler secret bulk .dev.vars --name \"$WORKER_NAME\"",
    "test": "node --test"
  },
  "dependencies": {
    "hono": "^4.10.6"
  },
  "devDependencies": {
    "node-addon-api": "^8.6.0",
    "node-gyp": "^12.2.0",
    "wrangler": "^4.75.0"
  }
}
